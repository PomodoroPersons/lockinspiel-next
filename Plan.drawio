        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-48" edge="1" parent="1" source="DfyDkEkuF7y0-2PQH1cT-13" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.855;exitY=0;exitDx=0;exitDy=4.35;exitPerimeter=0;" target="DfyDkEkuF7y0-2PQH1cT-18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-13" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;" value="&lt;div&gt;PostgreSQL&lt;/div&gt;(Timescale DB)" vertex="1">
          <mxGeometry height="80" width="100" x="510" y="470" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Auth (:8080)&lt;/h1&gt;&lt;p&gt;Just keeps user info and handles authentication, so pretty straightforward.&lt;/p&gt;&lt;p&gt;The plan is to use JSON Web Tokens to handle sessions. JWT sessions require that a server with a secret private key issues tokens to users who are authorized by said server. All other microservices can then use the public keys exposed by the auth servers to verify that the user in question was authorized by at least one of them.&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;User data is planned to be stored in PostgreSQL&lt;/div&gt;" vertex="1">
          <mxGeometry height="328.57" width="180" x="145" y="221.43" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-17" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Realtime (:8083)&lt;/h1&gt;&lt;p&gt;Responsible for providing a synchronized Lockinspiel experience to multiple users. Provides things like chat, rich presenece-esque features, and other amentities to a Lockinspiel room.&lt;/p&gt;" vertex="1">
          <mxGeometry height="198.57" width="180" x="775" y="221.43" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-18" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Analyzer (:8082)&lt;/h1&gt;&lt;p&gt;Provides HTTP routes that read the user&#39;s time series data from ScyllaDB and provides analytics to be displayed in the user&#39;s dashboard.&lt;/p&gt;" vertex="1">
          <mxGeometry height="158.57" width="180" x="565" y="221.43" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-20" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Timekeeper (:8081)&lt;/h1&gt;&lt;p&gt;Responsible for the syncing the user&#39;s clock with the server&#39;s clock to within a 10th of a second. Also responsible for handling the write path of the user&#39;s time-series data to ScyllaDB.&lt;/p&gt;" vertex="1">
          <mxGeometry height="188.57" width="180" x="355" y="221.43" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-24" edge="1" parent="1" source="DfyDkEkuF7y0-2PQH1cT-23" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="DfyDkEkuF7y0-2PQH1cT-16">

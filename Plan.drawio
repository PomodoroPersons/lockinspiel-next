        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-29" edge="1" parent="1" source="DfyDkEkuF7y0-2PQH1cT-23" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="DfyDkEkuF7y0-2PQH1cT-20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-30" edge="1" parent="1" source="DfyDkEkuF7y0-2PQH1cT-23" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="DfyDkEkuF7y0-2PQH1cT-18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-23" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Lockinspiel&lt;/h1&gt;&lt;p&gt;Lockinspiel is a distributed Pomodoro timer that lets you synchonise your timers with your friends. Letting you work and take breaks together with your buds. It also provides helpful analytics and advise about how you&amp;nbsp;&lt;i&gt;use&lt;/i&gt;&amp;nbsp;your time.&lt;/p&gt;" vertex="1">
          <mxGeometry height="170" width="180" x="460" y="10" as="geometry" />
        </mxCell>
        <mxCell id="DfyDkEkuF7y0-2PQH1cT-33" edge="1" parent="1" source="DfyDkEkuF7y0-2PQH1cT-16" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.145;entryY=0;entryDx=0;entryDy=4.35;entryPerimeter=0;startArrow=classic;startFill=1;" target="DfyDkEkuF7y0-2PQH1cT-13">

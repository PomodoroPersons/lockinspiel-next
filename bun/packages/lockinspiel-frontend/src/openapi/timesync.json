{
  "openapi": "3.1.0",
  "info": {
    "title": "Timesync API",
    "description": "Just syncs your system clock's time with the server's time",
    "version": "0.1.0"
  },
  "paths": {
    "/timesync": {
      "get": {
        "tags": [
          "Time sync"
        ],
        "summary": "Get N2 and N3",
        "description": "To sync your clock and the server's clock, take timestamp N1, make the request to this endpoint, then take N4. Then do an NTP style calculation to find your clock's offset from the server's clock.",
        "operationId": "getN2N3",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "required": [
                    "n2",
                    "n3"
                  ],
                  "properties": {
                    "n2": {
                      "type": "integer"
                    },
                    "n3": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
